model Deposit {
  id            Int           @id @default(autoincrement())
  userId        Int           @map("user_id")
  amount        Decimal       @db.Decimal(10, 2)
  status        DepositStatus @default(pending)
  type          String?       @db.VarChar(50)
  externalId    String?       @unique @map("external_id") @db.VarChar(255)
